# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
# Service role / secret key (server-side only, bypasses RLS)
SUPABASE_KEY=your-supabase-service-role-key
# JWT secret for verifying user access tokens (legacy HS256)
# Dashboard → Project Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret

# Moonshot (Kimi) — used by summarizer.py and briefing.py
MOONSHOT_API_KEY=sk-xxxxxxxx
MOONSHOT_MODEL=kimi-k2.5
MOONSHOT_BASE_URL=https://api.moonshot.ai/v1

# Upstream services
EMBEDDING_SERVICE_URL=http://localhost:8002
QUESTION_SERVICE_URL=http://localhost:8003

# Briefing window (minutes after target hour to still trigger)
# BRIEFING_WINDOW_MINUTES=15
